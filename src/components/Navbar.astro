---
// components/Navbar.astro
---

<nav class="header">
  <div class="container">
    <div class="header-content">
      
      <!-- Logo Section -->
      <div class="logo">
        <div class="logo-icon">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div class="logo-text">
          <h1>Harvard TODO & Notes</h1>
          <p>Final Project - CS50</p>
        </div>
      </div>

      <!-- Desktop Navigation -->
      <div class="nav-buttons">
        <button class="btn" aria-label="Search">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          Search
        </button>
        
        <button class="btn btn-blue" id="new-task-btn" aria-label="Create new task">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          New Task
        </button>
        
        <button class="btn btn-green" id="new-note-btn" aria-label="Create new note">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C20.168 18.477 18.582 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          New Note
        </button>
        
        <button class="btn btn-icon" id="settings-btn" aria-label="Settings">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button class="navbar-mobile-toggle" id="mobile-menu-btn" aria-label="Toggle mobile menu">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div class="navbar-mobile-menu" id="mobile-menu">
      <button class="btn btn-mobile" id="search-btn-mobile" aria-label="Search">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Search
      </button>
      
      <button class="btn btn-blue btn-mobile" id="new-task-btn-mobile" aria-label="Create new task">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        New Task
      </button>
      
      <button class="btn btn-green btn-mobile" id="new-note-btn-mobile" aria-label="Create new note">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C20.168 18.477 18.582 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
        New Note
      </button>
      
      <button class="btn btn-mobile" id="settings-btn-mobile" aria-label="Settings">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        Settings
      </button>
    </div>
  </div>
</nav>


<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
    });

    document.addEventListener('click', (e) => {
      if (!mobileMenuBtn.contains(e.target as Node) && !mobileMenu.contains(e.target as Node)) {
        mobileMenu.classList.remove('active');
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        mobileMenu.classList.remove('active');
      }
    });
  }

  if (typeof gsap !== 'undefined') {
    gsap.fromTo('.logo', 
      { opacity: 0, x: -50 }, 
      { opacity: 1, x: 0, duration: 0.8, delay: 0.2 }
    );

    gsap.fromTo('.nav-buttons', 
      { opacity: 0, x: 50 }, 
      { opacity: 1, x: 0, duration: 0.8, delay: 0.4 }
    );

    const buttons = document.querySelectorAll('.btn');
    buttons.forEach(button => {
      button.addEventListener('mouseenter', () => {
        gsap.to(button, { 
          y: -2, 
          boxShadow: '6px 6px 0px 0px rgba(0,0,0,1)', 
          duration: 0.2 
        });
      });
      
      button.addEventListener('mouseleave', () => {
        gsap.to(button, { 
          y: 0, 
          boxShadow: '4px 4px 0px 0px rgba(0,0,0,1)', 
          duration: 0.2 
        });
      });
    });

    const mobileMenuItems = document.querySelectorAll('.btn-mobile');
    mobileMenuBtn?.addEventListener('click', () => {
      if (mobileMenu?.classList.contains('active')) {
        gsap.fromTo(mobileMenuItems, 
          { opacity: 0, y: -20 }, 
          { opacity: 1, y: 0, duration: 0.3, stagger: 0.1 }
        );
      }
    });
  }

  const handleSearch = () => {
    console.log('Opening search functionality');
  };

  const handleNewTask = () => {
    console.log('Opening new task modal');
  };

  const handleNewNote = () => {
    console.log('Opening new note modal');
  };

  const handleSettings = () => {
    console.log('Opening settings');
  };

  document.getElementById('new-task-btn')?.addEventListener('click', handleNewTask);
  document.getElementById('new-note-btn')?.addEventListener('click', handleNewNote);
  document.getElementById('settings-btn')?.addEventListener('click', handleSettings);

  document.getElementById('search-btn-mobile')?.addEventListener('click', handleSearch);
  document.getElementById('new-task-btn-mobile')?.addEventListener('click', handleNewTask);
  document.getElementById('new-note-btn-mobile')?.addEventListener('click', handleNewNote);
  document.getElementById('settings-btn-mobile')?.addEventListener('click', handleSettings);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
      mobileMenu.classList.remove('active');
      mobileMenuBtn?.focus();
    }
  });

  const trapFocus = (element: HTMLElement) => {
    const focusableElements = element.querySelectorAll(
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    const firstElement = focusableElements[0] as HTMLElement;
    const lastElement = focusableElements[focusableElements.length - 1] as HTMLElement;

    element.addEventListener('keydown', (e) => {
      if (e.key === 'Tab') {
        if (e.shiftKey) {
          if (document.activeElement === firstElement) {
            lastElement.focus();
            e.preventDefault();
          }
        } else {
          if (document.activeElement === lastElement) {
            firstElement.focus();
            e.preventDefault();
          }
        }
      }
    });
  };

  if (mobileMenu) {
    trapFocus(mobileMenu);
  }
</script>